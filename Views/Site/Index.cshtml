@{
    ViewData["Title"] = "SuperControl Listing Site Demo";
}

<section class="sc-wrap">
    <div class="ambient-orb orb-a"></div>
    <div class="ambient-orb orb-b"></div>
    <div class="sc-panel">
        <p class="kicker">Standalone Demo</p>
        <h1>SuperControl Listing Site Demo</h1>
        <p class="lead">MVC demo project for SuperControl API diagnostics, listing search, and property detail/tutorial views.</p>

        <div class="sc-grid">
            <article class="sc-card">
                <h2>Pages</h2>
                <p><a class="text-link" href="/supercontrol-demo">/supercontrol-demo</a></p>
                <p><a class="text-link" href="/supercontrol-listing-site-demo">/supercontrol-listing-site-demo</a></p>
                <p><a class="text-link" href="/supercontrol-listing-site-tutorial">/supercontrol-listing-site-tutorial</a></p>
            </article>

            <article class="sc-card">
                <h2>Config</h2>
                <pre class="sc-pre">SuperControl__ApiKey=your-supercontrol-sc-token
SuperControl__AccountId=22263
SuperControl__BaseUrl=https://api.supercontrol.co.uk/v3/
SuperControl__CalendarKey=your-supercontrol-calendar-key</pre>
            </article>
        </div>
    </div>
</section>